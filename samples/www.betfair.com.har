CKBOX\":{\"LITERAL\":\"Betfair SP\",\"SMALL\":\"BSP\"}},\"CASHOUT\":{\"AUTO_CASHOUT\":{\"HELP\":{\"DESCRIPTION\":\"Enter the profit value in the box provided and we will automatically Cash Out the market if the profit reaches the value you set.\",\"INTRO\":\"Auto Cash Out allows you to set a profit value at which you'd like to Cash Out.\",\"TITLE\":\"Auto Cash Out\"},\"NOT_SAVED\":\"Auto Cash Out not saved\",\"PROFIT_AMOUNT_EXCEEDS\":\"Profit amount exceeds maximum profit.\",\"REMOVING_ERROR\":\"Error removing Auto Cash Out\",\"SAVING_ERROR\":\"Error saving Auto Cash Out\",\"TRY_AGAIN\":\"Please try again.\"},\"CASHINGOUT\":\"Cashing Out...\",\"HELP\":{\"FAQS\":\"Cash Out FAQs\",\"VIDEOTUTORIAL\":\"Video Tutorial\"},\"HELPINTRO\":{\"FIRST\":\"Cash Out is a product from Betfair that allows you to lock in a profit or loss before waiting for the event to finish.\",\"SECOND\":\"Betfair do the maths to offer you a value in real time of your current bets based on the live market prices.\",\"THIRD\":\"Using a single click you can cash out of all bets placed on a single market.\"},\"HELPTITLE\":\"What is Cash Out?\",\"LABEL\":\"Cash Out\",\"LATEWITHDRAWAL\":\"Cash Out no longer available.\",\"ODDSCHANGED\":\"The odds have changed. Please try again\",\"PARTIAL_CASHOUT\":{\"HELP\":{\"DESCRIPTION\":\"Moving the slider will change the Cash Out amount and the \\\"what if\\\" figures for your P&L.\",\"INTRO\":\"Partial Cash Out allows you to choose to Cash Out part of your bet.\",\"LINK\":\"Partial Cash Out Video Tutorial\\n\",\"TITLE\":\"Cash Out Partial\"}},\"SUCCESSFUL\":\"Your Cash Out was successful\",\"SUSPENDED\":\"The Market has been suspended\",\"UNSUCCESSFUL\":\"Cash Out unsuccessful\"},\"CASHOUT_PAGE\":{\"ABOUT_FIND_MORE\":\"Find out more.\",\"ABOUT_TEXT_1\":\"Cash Out is a revolutionary feature from Betfair that puts the power in your hands. With Cash Out, you can lock in a profit or cut your losses during a match, race or event. No longer do you have to wait until it’s finished to take your winnings.\",\"ABOUT_TEXT_2\":\"Betfair crunch the live market numbers in real-time to give you the value of your In-Play bets. Simply hit the yellow button when you want to Cash Out. With Betfair, you decide. \",\"LOGGED_OUT\":\"Please log in, in order to see your Cash Out Markets\",\"NO_CASHOUTS\":\"You currently have no Cash Outs available\"},\"COUNTRIES\":{\"ABW\":\"Aruba\",\"AFG\":\"Afghanistan\",\"AGO\":\"Angola\",\"AIA\":\"Anguilla\",\"ALA\":\"Åland Islands\",\"ALB\":\"Albania\",\"AND\":\"Andorra\",\"ARE\":\"United Arab Emirates\",\"ARG\":\"Argentina\",\"ARM\":\"Armenia\",\"ASM\":\"American Samoa\",\"ATA\":\"Antarctica\",\"ATF\":\"French Southern Territories\",\"ATG\":\"Antigua and Barbuda\",\"AUS\":\"Australia\",\"AUT\":\"Austria\",\"AZE\":\"Azerbaijan\",\"BDI\":\"Burundi\",\"BEL\":\"Belgium\",\"BEN\":\"Benin\",\"BES\":\"Bonaire Sint Eustatius and Saba\",\"BFA\":\"Burkina Faso\",\"BGD\":\"Bangladesh\",\"BGR\":\"Bulgaria\",\"BHR\":\"Bahrain\",\"BHS\":\"Bahamas\",\"BIH\":\"Bosnia and Herzegovina\",\"BLM\":\"Saint Barthélemy\",\"BLR\":\"Belarus\",\"BLZ\":\"Belize\",\"BMU\":\"Bermuda\",\"BOL\":\"Bolivia\",\"BRA\":\"Brazil\",\"BRB\":\"Barbados\",\"BRN\":\"Brunei Darussalam\",\"BTN\":\"Bhutan\",\"BVT\":\"Bouvet Island\",\"BWA\":\"Botswana\",\"CAF\":\"Central African Republic\",\"CAN\":\"Canada\",\"CCK\":\"Cocos (Keeling) Islands\",\"CHE\":\"Switzerland\",\"CHL\":\"Chile\",\"CHN\":\"China\",\"CIV\":\"Côte d'Ivoire\",\"CMR\":\"Cameroon\",\"COD\":\"Congo the Democratic Republic of the\",\"COG\":\"Congo\",\"COK\":\"Cook Islands\",\"COL\":\"Colombia\",\"COM\":\"Comoros\",\"CPV\":\"Cabo Verde\",\"CRI\":\"Costa Rica\",\"CUB\":\"Cuba\",\"CUW\":\"Curaçao\",\"CXR\":\"Christmas Island\",\"CYM\":\"Cayman Islands\",\"CYP\":\"Cyprus\",\"CZE\":\"Czech Republic\",\"DEU\":\"Germany\",\"DJI\":\"Djibouti\",\"DMA\":\"Dominica\",\"DNK\":\"Denmark\",\"DOM\":\"Dominican Republic\",\"DZA\":\"Algeria\",\"ECU\":\"Ecuador\",\"EGY\":\"Egypt\",\"ERI\":\"Eritrea\",\"ESH